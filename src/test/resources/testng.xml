<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Playwright Test Suite" verbose="2" parallel="none">

    <listeners>
        <listener class-name="com.automation.base.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.automation.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Inventory Tests">
        <classes>
            <class name="com.automation.tests.InventoryTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.automation.tests.CartTest"/>
        </classes>
    </test>

</suite>
